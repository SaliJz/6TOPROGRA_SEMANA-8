  - m_Id: 14
    m_Localized: ignorarlo
    m_Metadata:
      m_Items: []
  - m_Id: 15
    m_Localized: Leer los libros
    m_Metadata:
      m_Items: []
  - m_Id: 16
    m_Localized: Quemar los libros
    m_Metadata:
      m_Items: []
  - m_Id: 17
    m_Localized: ayudarlo
    m_Metadata:
      m_Items: []
  - m_Id: 18
    m_Localized: dejarlo a su suerte
    m_Metadata:
      m_Items: []
  - m_Id: 19
    m_Localized: tomar el tesoro
    m_Metadata:
      m_Items: []
  - m_Id: 20
    m_Localized: saltar con cuidado
    m_Metadata:
      m_Items: []
  - m_Id: 21
    m_Localized: correr rapido
    m_Metadata:
      m_Items: []
  - m_Id: 22
    m_Localized: enfrentarlo
    m_Metadata:
      m_Items: []
  - m_Id: 23
    m_Localized: romperlo
    m_Metadata:
      m_Items: []
  - m_Id: 24
    m_Localized: Atacar
    m_Metadata:
      m_Items: []
